flowchart LR
    subgraph FE["Frontend — Next.js 14"]
        FE_Upload["Upload Modal\nXHR onprogress bar"]
        FE_Chat["Chat + Query UI\nsource cards · highlighting"]
        FE_Modal["Artifact Detail Modal\nchunks · provenance · pills"]
        FE_SSE["EventSource SSE\nstatus updates"]
    end
    subgraph API["API — FastAPI :8000"]
        API_Upload["POST /upload"]
        API_Stream["GET /artifacts/stream\nSSE · push every 1s"]
        API_Query["POST /query"]
        API_Chat["POST /conversations/id/messages"]
        API_Delete["DELETE /artifacts/id"]
    end
    subgraph PIPE["Ingestion + Chunking  (synchronous)"]
        ING_D["Docling Parser\nPDF + DOCX\nDocLayNet + TableFormer"]
        ING_X["pandas Parser\nXLSX rows"]
        CHK_M["MarkdownChunker\nLangChain RCTS\nbreadcrumb + page provenance"]
        CHK_X["XlsxChunker\nsheet + row provenance"]
        ENR["Contextual Enricher\nOllama gemma3:4b\n— optional —"]
    end
    subgraph BG["Background Embedding  (async task)"]
        VLM["VLM Figures\nqwen3-vl · ChromaDB only\n— optional —"]
        EMB["LangChain OllamaEmbeddings\nnomic-embed-text 768-dim\nlangchain-chroma upsert"]
        D2Q["Doc2Query\n3 questions per chunk\nOllama gemma3:4b\n— optional —"]
        COPY["Vector Copy\nzero Ollama calls\nif same file already indexed"]
    end
    subgraph ST["Storage"]
        SQL[("SQLite WAL + NullPool\nartifacts · chunks · conversations · messages\nFTS5 virtual table · BM25 · 3 sync triggers")]
        BLB[("Blob Store\ndata/uploads/sha256.ext\nref-counted GC")]
        CHR[("ChromaDB\nchunks collection\nquestions collection")]
    end
    subgraph RET["Retrieval"]
        KW["FTS5 keyword search\nBM25 · sanitised tokens\nchar-level match_positions"]
        SEM["Semantic search\nsimilarity_search_with_score\nChromaDB HNSW cosine"]
        RRF["RRF Fusion\n1/(60+rank)\nhybrid · keyword · semantic badges"]
        FMT["Result Formatter\nProvenanceRef per chunk"]
    end
    subgraph LLM["LLM — Ollama on host"]
        RAG["LangChain LCEL\nPromptTemplate | OllamaLLM | StrOutputParser\ngemma3:4b · last-4-turn history\ngraceful fallback to excerpts"]
    end

    FE_Upload -->|"XHR multipart"| API_Upload
    API_Upload -->|"sha256 · skip if exists"| BLB
    API_Upload --> ING_D & ING_X
    ING_D --> CHK_M
    ING_X --> CHK_X
    CHK_M & CHK_X --> ENR
    ENR -->|"ChunkRecord + provenance JSON"| SQL
    ENR -->|"text via 3 FTS triggers"| SQL
    API_Upload -->|"background_tasks.add_task"| BG
    ING_D -->|"figures_b64 in extracted_metadata"| VLM
    VLM -->|"enriched text · SQLite unchanged"| EMB
    ENR --> EMB
    EMB -->|"chunk vectors"| CHR
    EMB --> D2Q -->|"question vectors"| CHR
    EMB -->|"embedding_status = ready"| SQL
    API_Upload -->|"same hash · copy vectors"| COPY --> CHR
    FE_SSE <-->|"persistent · push on change · event:done"| API_Stream <--> SQL
    FE_Chat --> API_Query --> KW & SEM
    KW --> SQL
    SEM --> CHR
    KW & SEM --> RRF --> FMT --> FE_Chat
    FE_Chat --> API_Chat --> RRF --> RAG --> FE_Chat
    FE_Modal --> API_Delete -->|"GC if last ref"| BLB & SQL & CHR
